# ==============================================================================
# fusionAIze Nexus Labs — Topology Configuration Template
# Copy to .env.topology and fill in your actual values.
# This file is gitignored — never commit your real .env.topology.
# ==============================================================================

# ------------------------------------------------------------------------------
# Node SSH Targets
# Used by the orchestrator to auto-detect node state in the Grid Overview.
# Format: user@<ip-or-hostname>
# Leave blank or comment out nodes that are not part of your grid.
# ------------------------------------------------------------------------------
CORE_TARGET=nexus@192.168.x.x
EDGE_TARGET=nexus@192.168.x.x
WORKER_TARGET=nexus@192.168.x.x
BACKUP_TARGET=nexus@192.168.x.x
EXTERNAL_TARGET=deploy@your-vps-hostname

# ------------------------------------------------------------------------------
# Active Node Role (set by the orchestrator on each run — do not edit manually)
# ------------------------------------------------------------------------------
# SERVER_NAME=edge-node
# ROLE=edge

# ------------------------------------------------------------------------------
# Role-Specific Options
# ------------------------------------------------------------------------------
# ENABLE_VNC=false          # nexus-core: enable VNC GUI for AI Workbench
# DO_PIHOLE_UPDATE=0        # nexus-edge: set to 1 to also update Pi-hole on Update
