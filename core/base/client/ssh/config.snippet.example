# SSH config snippet (example)
# Copy relevant blocks into ~/.ssh/config
# Adjust IPs/keys for your environment. Do NOT commit private keys.

# --- grid-edge (edge node) ---
Host grid-edge
  HostName 192.168.178.10
  User grid
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3
  Compression yes

# --- grid-core (admin/bootstrap) ---
Host grid-core
  HostName 192.168.178.20
  User grid
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3
  Compression yes

# --- grid-core (daily ops) ---
Host grid-core-ops
  HostName 192.168.178.20
  User grid-ops
  IdentitiesOnly yes
  IdentityFile ~/.ssh/grid_core_backup_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3
  Compression yes

# (future) worker + backup placeholders:
# Host grid-worker
#   HostName 192.168.178.30
#   User grid-ops
#
# Host grid-backup
#   HostName 192.168.178.40
#   User grid-ops
