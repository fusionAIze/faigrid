TZ=Europe/Berlin
NEXUS_STACK_NAME=nexus-core-heart

# n8n
N8N_HOST=n8n.lan
N8N_PORT=5678
N8N_BIND_IP=127.0.0.1
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://n8n.lan/
N8N_ENCRYPTION_KEY=CHANGE_ME_32+_CHARS_MIN
N8N_USER_FOLDER=/home/node/.n8n

# temporary guard (prefer SSO in front instead)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# webhook signing shared secret
WEBHOOK_SHARED_SECRET=CHANGE_ME

# postgres
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# redis
REDIS_HOST=redis
REDIS_PORT=6379

# openclaw (placeholder)
OPENCLAW_HOST=openclaw
OPENCLAW_PORT=3000
