# OpenClaw gateway env example (NO SECRETS IN GIT)
#
# This file mirrors the host-side defaults used by `native/server/install.sh`.
# Real tokens live in `/etc/openclaw/openclaw.token.env`, not here.

TZ=Europe/Berlin
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_AUTH=token
