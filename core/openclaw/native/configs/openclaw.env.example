# OpenClaw (native) - example env file (NO SECRETS IN GIT)

TZ=Europe/Berlin

# Where OpenClaw will live on nexus-core
OPENCLAW_INSTALL_DIR=/opt/openclaw
OPENCLAW_DATA_DIR=/var/lib/openclaw
OPENCLAW_LOG_DIR=/var/log/openclaw

# Bind settings (recommend: localhost only, expose via edge reverse proxy later)
OPENCLAW_HOST=127.0.0.1
OPENCLAW_PORT=3000

# Optional: Base URL used by web UI when behind proxy
# OPENCLAW_PUBLIC_URL=https://openclaw.example.com

# LLM / integrations placeholders (keep generic; project-specific later)
# OPENCLAW_LLM_PROVIDER=lmstudio|openai|...
# OPENCLAW_LMSTUDIO_BASE_URL=http://nexus-llm-worker.lan:1234
