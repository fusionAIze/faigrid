#!/usr/bin/env bash
set -euo pipefail

START_PORT="${START_PORT:-19089}"
COUNT="${COUNT:-20}"

DIALOG_TITLE="${DIALOG_TITLE:-OpenClaw UI}"

osasay() {
  /usr/bin/osascript -e "display dialog \"$1\" with title \"${DIALOG_TITLE}\" buttons {\"OK\"} default button \"OK\"" >/dev/null
}

have() { command -v "$1" >/dev/null 2>&1; }

if ! have lsof; then
  echo "ERROR: lsof missing" >&2
  exit 1
fi

killed=0
for ((i=0;i<COUNT;i++)); do
  port=$((START_PORT+i))
  PIDS="$(lsof -nP -iTCP:"${port}" -sTCP:LISTEN -t 2>/dev/null | tr '\n' ' ' || true)"
  if [[ -n "${PIDS// }" ]]; then
    kill ${PIDS} >/dev/null 2>&1 || true
    killed=1
  fi
done

if [[ "${killed}" -eq 1 ]]; then
  osasay "Stopped OpenClaw tunnel listeners on ports ${START_PORT}..$((START_PORT+COUNT-1))."
else
  osasay "No OpenClaw tunnel listener found on ports ${START_PORT}..$((START_PORT+COUNT-1))."
fi
