#!/usr/bin/env bash
set -euo pipefail

HOST_ALIAS="${HOST_ALIAS:-nexus-core-ops}"

LOCAL_PORT="${LOCAL_PORT:-19089}"
REMOTE_HOST="${REMOTE_HOST:-127.0.0.1}"
REMOTE_PORT="${REMOTE_PORT:-18789}"

TOKEN_CMD_PRIMARY="${TOKEN_CMD_PRIMARY:-/bin/cat /etc/openclaw/secret/gateway.token}"
TOKEN_CMD_FALLBACK="${TOKEN_CMD_FALLBACK:-sudo -n /bin/cat /etc/openclaw/secret/gateway.token}"

UI_PATH="${UI_PATH:-/__openclaw__/canvas/}"

DIALOG_TITLE="${DIALOG_TITLE:-OpenClaw UI}"
SSH_OPTS=(-o BatchMode=yes -o ExitOnForwardFailure=yes)

osasay() {
  /usr/bin/osascript -e "display dialog \"$1\" with title \"${DIALOG_TITLE}\" buttons {\"OK\"} default button \"OK\"" >/dev/null
}

have() { command -v "$1" >/dev/null 2>&1; }

if ! have ssh; then
  echo "ERROR: ssh missing" >&2
  exit 1
fi

TOKEN="$(ssh "${SSH_OPTS[@]}" "${HOST_ALIAS}" "${TOKEN_CMD_PRIMARY}" 2>/dev/null | tr -d '\r\n' || true)"
if [[ -z "${TOKEN}" ]]; then
  TOKEN="$(ssh "${SSH_OPTS[@]}" "${HOST_ALIAS}" "${TOKEN_CMD_FALLBACK}" 2>/dev/null | tr -d '\r\n' || true)"
fi
if [[ -z "${TOKEN}" ]]; then
  osasay "Could not read a valid OpenClaw token from ${HOST_ALIAS}.\n\nTest:\n  ssh ${HOST_ALIAS} '${TOKEN_CMD_FALLBACK}'"
  exit 1
fi

if have lsof; then
  PIDS="$(lsof -nP -iTCP:"${LOCAL_PORT}" -sTCP:LISTEN -t 2>/dev/null | tr '\n' ' ' || true)"
  if [[ -n "${PIDS// }" ]]; then
    kill ${PIDS} >/dev/null 2>&1 || true
    sleep 0.2
  fi
fi

ssh "${SSH_OPTS[@]}" -fN \
  -L "${LOCAL_PORT}:${REMOTE_HOST}:${REMOTE_PORT}" \
  "${HOST_ALIAS}"

URL="http://127.0.0.1:${LOCAL_PORT}${UI_PATH}?token=${TOKEN}"
/usr/bin/open "${URL}" >/dev/null 2>&1 || true

osasay "Tunnel up.\n\n${URL}\n\nTo stop:\n  nexus-openclaw-ui-stop"
