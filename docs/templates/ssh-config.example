# Example ~/.ssh/config entries (client side)
# Copy the blocks you need into your local ~/.ssh/config
# Never commit private keys.

Host nexus-edge
  HostName 192.168.178.10
  User nexus
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host nexus-core
  HostName 192.168.178.20
  User nexus
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3

# Daily ops user (core)
Host nexus-core-ops
  HostName 192.168.178.20
  User nexus-ops
  IdentitiesOnly yes
  IdentityFile ~/.ssh/nexus_core_backup_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3
