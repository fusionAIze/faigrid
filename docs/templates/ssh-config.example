# Example ~/.ssh/config entries (client side)
# Copy the blocks you need into your local ~/.ssh/config
# Never commit private keys.

Host grid-edge
  HostName 192.168.178.10
  User grid
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3

Host grid-core
  HostName 192.168.178.20
  User grid
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3

# Daily ops user (core)
Host grid-core-ops
  HostName 192.168.178.20
  User grid-ops
  IdentitiesOnly yes
  IdentityFile ~/.ssh/grid_core_backup_ed25519
  ServerAliveInterval 30
  ServerAliveCountMax 3
