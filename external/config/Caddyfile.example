{
    email ${ACME_EMAIL}
}

# n8n External Node
${N8N_HOST} {
    reverse_proxy grid-external-n8n:5678
}

# Plane.so External Node
${PLANE_HOST} {
    # Web Frontend
    reverse_proxy nexus-plane-web:3000

    # API handles /api
    handle /api/* {
        reverse_proxy nexus-plane-api:8000
    }

    # SECURE DASHBOARD (Basic Auth)
    handle /stats/* {
        basicauth {
            # User: nexus, Password: generate via 'caddy hash-password'
            nexus ${CADDY_STATS_PWD_HASH}
        }
        root * /var/www/nexus
        file_server browse
    }
}
